{
  "name": "uni-ui-snippets-vscode",
  "displayName": "uni-ui-snippets",
  "version": "0.7.1",
  "description": "uni-ui 基本能力代码片段。",
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "uniapp",
    "uni-app",
    "uni-ui",
    "uniui",
    "snippet",
    "snippets"
  ],
  "homepage": "https://github.com/uni-helper/uni-ui-snippets-vscode#readme",
  "bugs": {
    "url": "https://github.com/uni-helper/uni-ui-snippets-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uni-helper/uni-ui-snippets-vscode"
  },
  "license": "MIT",
  "author": {
    "name": "ModyQyW",
    "email": "wurui-dev@foxmail.com",
    "url": "https://modyqyw.github.io"
  },
  "publisher": "uni-helper",
  "type": "module",
  "files": [
    "snippets",
    "LICENSE",
    "uni-helper.png"
  ],
  "scripts": {
    "fix": "ultracite fix",
    "prepare": "is-ci || lefthook install",
    "publish": "conc \"npm:publish:vscode\" \"npm:publish:openvsx\"",
    "publish:openvsx": "ovsx publish",
    "publish:vscode": "vsce package && vsce publish",
    "release": "bumpp --all -x=\"tsx ./scripts/update-readme.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "contributes": {
    "snippets": [
      {
        "language": "vue-html",
        "path": "./snippets/vue-html.json"
      },
      {
        "language": "vue",
        "path": "./snippets/vue-html.json"
      },
      {
        "language": "html",
        "path": "./snippets/vue-html.json"
      }
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vscode/vsce": "^3.9.2",
    "bumpp": "^11.1.0",
    "concurrently": "^10.0.3",
    "is-ci": "^4.1.0",
    "lefthook": "^2.1.9",
    "ovsx": "^1.0.2",
    "simple-git": "^3.36.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3"
  },
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=18",
    "vscode": "^1.40.0"
  },
  "icon": "uni-helper.png",
  "sponsor": {
    "url": "https://github.com/ModyQyW/sponsors"
  },
  "allowScripts": {
    "keytar@7.9.0": true,
    "esbuild@0.28.1": true,
    "@vscode/vsce-sign@2.0.9": true,
    "lefthook@2.1.9": true
  }
}
